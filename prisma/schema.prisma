generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  password      String
  defaultPeople Int      @default(2)
  createdAt     DateTime @default(now())

  recipes              UserRecipe[]
  extras               UserExtra[]
  ingredients          UserIngredient[]
  weekPlans            WeekPlan[]
  favourites           RecipeFavourite[]
  notes                RecipeNote[]
  ownedHousehold       Household?              @relation("HouseholdOwner")
  householdMemberships HouseholdMember[]
  sentInvites          HouseholdInvite[]       @relation("InviteSender")
  customShoppingItems  ShoppingCustomItem[]
}

model Household {
  id        String   @id @default(cuid())
  name      String   @default("My Household")
  ownerId   String   @unique
  owner     User     @relation("HouseholdOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members             HouseholdMember[]
  invites             HouseholdInvite[]
  weekPlans           WeekPlan[]
  customShoppingItems ShoppingCustomItem[]
  createdAt           DateTime @default(now())
}

model HouseholdMember {
  householdId String
  userId      String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@id([householdId, userId])
}

model HouseholdInvite {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User      @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  token       String    @unique @default(cuid())
  note        String?
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

model UserRecipe {
  id                String   @id
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  labels            String[]
  cuisine           String?
  prepTimeISO       String
  caloriesPerPerson Int
  recipeYield       Int
  instructions      String[]
  ingredients       Json
  sourceUrl         String?
  youtubeUrl        String?
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model UserExtra {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  emoji     String
  category  String
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserIngredient {
  id          String   @id
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  defaultUnit String
  aisle       String
  createdAt   DateTime @default(now())
}

model WeekPlan {
  id          String     @id @default(cuid())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)
  weekStart   String
  data        Json
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, weekStart])
  @@unique([householdId, weekStart])
}

model ShoppingCustomItem {
  id          String     @id @default(cuid())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)
  name        String
  inCart      Boolean    @default(false)
  createdAt   DateTime   @default(now())
}

model RecipeFavourite {
  userId   String
  recipeId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
}

model RecipeNote {
  userId   String
  recipeId String
  note     String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
}
